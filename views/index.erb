<div data-controller="blocks">
  <nav class="mb-1">
    <div class="flex justify-between items-center gap-1">
      <div class="flex gap-1">
        <a href="#" class="nav-link active" data-blocks-target="navUpcoming" data-action="click->blocks#showUpcoming:prevent">Upcoming</a>
        <a href="#" class="nav-link" data-blocks-target="navHistory" data-action="click->blocks#showHistory:prevent">History</a>
      </div>
      <a href="/releases.ics" class="nav-link [&>svg]:w-4 [&>svg]:h-4 inline-flex items-center gap-1" data-controller="ical" data-action="click->ical#copy:prevent" title="Subscribe to calendar"><%= File.read('assets/images/calendar.svg').strip %> iCal</a>
    </div>
  </nav>

  <template data-blocks-target="template">
    <div class="release-block">
      <div class="flex justify-between items-start mb-4 h-full" data-field="header">
        <div class="mr-4">
          <span class="font-bold text-xl leading-none uppercase block -mt-0.5" data-field="name"></span>
          <p class="text-sm text-catppuccin-subtext0" data-field="title"></p>
        </div>
        <div class="text-right">
          <p class="local-time" data-controller="time" data-field="time"></p>
        </div>
      </div>
      <div class="flex justify-between items-end mt-8" data-field="footer">
        <div class="button-bar" data-field="buttons"></div>
        <div class="countdown" data-controller="countdown" data-field="countdown">
          <span data-countdown-target="display"></span>
        </div>
      </div>
    </div>
  </template>

  <div data-blocks-target="container"></div>
</div>
