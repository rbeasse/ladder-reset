BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//gobh.at//Releases//EN
CALSCALE:GREGORIAN
METHOD:PUBLISH
<% game_releases.each do |release| %>
<% release_time = Time.parse(release['time'])
   end_of_day = Time.new(release_time.year, release_time.month, release_time.day, 0, 0, 0, release_time.utc_offset) + 86400 %>
BEGIN:VEVENT
UID:<%= release['name'] %>-<%= release_time.strftime('%Y%m%d') %>@gobh.at
SUMMARY:<%= release['name'] %> - <%= release['title'] %>
DTSTART:<%= release_time.utc.strftime('%Y%m%dT%H%M%SZ') %>
DTEND:<%= end_of_day.utc.strftime('%Y%m%dT%H%M%SZ') %>
END:VEVENT
<% end %>
END:VCALENDAR
