BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//gobh.at//Releases//EN
CALSCALE:GREGORIAN
METHOD:PUBLISH
<% game_releases.each do |release| %>
BEGIN:VEVENT
UID:<%= release['name'] %>-<%= Time.parse(release['time']).strftime('%Y%m%d') %>@gobh.at
SUMMARY:<%= release['name'] %> - <%= release['title'] %>
DTSTART:<%= Time.parse(release['time']).utc.strftime('%Y%m%dT%H%M%SZ') %>
DTEND:<%= Time.parse(release['time']).utc.strftime('%Y%m%dT%H%M%SZ') %>
END:VEVENT
<% end %>
END:VCALENDAR
